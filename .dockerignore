# ── 虛擬環境（由 pip install 在 container 內重建）──────────────────────────────
.venv/

# ── 敏感資料（由 env_file / volume 注入，不燒入 image）──────────────────────
.env
fox_trading.db
fox_sandbox_state*.json

# ── IDE / 工具 ────────────────────────────────────────────────────────────────
.claude/
.idea/
.vscode/
.git/
.gitignore

# ── Python 暫存 ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/

# ── 文件 ─────────────────────────────────────────────────────────────────────
README.md
*.md

# ── 系統檔案 ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
